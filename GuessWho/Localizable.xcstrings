    "home.action.message" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Add at least three photos for each parent to activate the model. More photos help the app choose better samples for steadier training."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "モデルを有効にするには、親それぞれに少なくとも3枚の写真を追加してください。写真が多いほど、より良いサンプルを選べて学習が安定しやすくなります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "부모 각각 최소 3장씩 등록하면 모델이 활성화됩니다. 사진이 많을수록 품질 좋은 샘플을 골라 더 안정적으로 학습할 수 있어요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "父母双方各至少添加 3 张照片后，模型才会启用。照片越多，应用越能挑选出更优质的样本，让训练更稳定。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "父母雙方各至少加入 3 張照片後，模型才會啟用。照片越多，App 越能挑出更優質的樣本，讓訓練更穩定。"
          }
        }
      }
