    "help.single_face.message" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Photos where one face fills most of the frame work best. Small faces or group shots may be excluded from training."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1人の顔が画面の大部分を占める写真が最適です。顔が小さい写真や集合写真は学習から除外されることがあります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "얼굴이 너무 작거나 여러 명이 같이 나온 사진은 학습에서 제외될 수 있어요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "照片中最好只有一张较大的单人脸。人脸过小或多人合照可能会被排除在训练之外。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "照片中最好只有一張較大的單人臉。人臉太小或多人合照可能會被排除在訓練之外。"
          }
        }
      }
    },
