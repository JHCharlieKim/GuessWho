    "ad.result_gate.message" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sometimes we show a full-screen ad before opening the result to support the app. Finish watching the ad to unlock this result."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アプリ運営のため、結果を開く前に全画面広告が表示されることがあります。広告の視聴が終わると今回の結果を開けます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "앱 수익화를 위해 일부 결과 열기 전에 전체 화면 광고가 표시될 수 있어요. 광고 시청이 끝나면 이번 결과를 열 수 있습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "为支持应用运营，在打开结果前有时会显示全屏广告。观看完成后即可解锁本次结果。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "為了支援 App 營運，在開啟結果前有時會顯示全螢幕廣告。觀看完成後即可解鎖這次結果。"
          }
        }
      }
    },
